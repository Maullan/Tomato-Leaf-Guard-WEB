# File ini boleh masuk Git, isinya hanya contoh tanpa nilai asli.
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
SECRET_KEY=your-secret-key-here
DEBUG=True

# Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# AI model
MODEL_PATH=ai_model/model_tomato_leaf_guardai.keras
REMOVE_BACKGROUND_ENABLED=True
PROCESSED_UPLOAD_DIR=uploads/processed
# Opsional. Jika kosong, backend membaca ukuran input dari file model.
# MODEL_INPUT_SIZE=128
# Opsional. Isi sesuai urutan class saat training model.
